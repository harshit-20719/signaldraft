# SignalDraft — required environment variables.
#
# This file documents the keys the app needs. It is committed to git as a
# template and contains NO real secrets.
#
# To run locally: copy this file to ".env.local" and fill in your own keys.
# ".env.local" is gitignored and is never committed.

# Anthropic API key — powers every Claude call (resolve, extract, draft).
# Get it from https://console.anthropic.com/  (the key starts with "sk-ant-").
ANTHROPIC_API_KEY=

# Tavily API key — powers all web search (news, press, podcasts, talks,
# job postings, company blog, and public LinkedIn snippets).
# Get it from https://app.tavily.com/  (the key starts with "tvly-").
TAVILY_API_KEY=

# --- Run-history store (Upstash Redis) — OPTIONAL for local dev ---------------
# The dashboard's shared run history lives in Upstash Redis. If these are unset,
# the app falls back to an in-memory store (local dev only: runs are not shared
# and are lost on restart). Set them to use the real shared store — required in
# production (the deployed dashboard needs them to persist + share runs).
#
# Provision via the Upstash for Redis integration in the Vercel Marketplace
# (injects KV_REST_API_*), or directly at https://upstash.com/ (gives
# UPSTASH_REDIS_REST_*). Either naming works; fill in whichever pair you have.
KV_REST_API_URL=
KV_REST_API_TOKEN=
